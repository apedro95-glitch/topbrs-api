# Caminho do JSON de service account do Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=/root/topbrs-api/service-account.json

# Documento no Firestore onde o app vai ler a URL da API
FIRESTORE_DOC_PATH=system/apiConfig
FIRESTORE_API_FIELD=clashApiBase

# Fonte dos logs do cloudflared: journalctl ou file
CLOUDFLARE_SOURCE=journalctl
# Se usar arquivo de log do cloudflared, informe aqui
CLOUDFLARED_LOG_PATH=/tmp/cloudflared.log

# Intervalo de atualização em ms quando usar --watch
SYNC_INTERVAL_MS=15000
